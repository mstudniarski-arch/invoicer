# Szablon — skopiuj do .env (które jest w .gitignore). Nie wpisuj prawdziwych sekretow tutaj.
# W produkcji (Fly) te same klucze ustawiasz przez `fly secrets set KLUCZ=...`.

# --- Rdzen (wymagane) ---
ANTHROPIC_API_KEY=
# Adres nadawcy faktur, ktorego skrzynka jest odpytywana (np. ksiegowa@firma.pl)
GMAIL_SENDER_FILTER=
# Token OAuth Gmaila (scope gmail.modify — odczyt + oznaczanie przeczytanych) base64: `base64 -i token.json`.
# Headless deploy odtwarza z niego /data/token.json przy starcie (gdy pliku jeszcze nie ma).
GMAIL_TOKEN_B64=

# --- Kanal akceptacji (Twilio WhatsApp, wymagane) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
APPROVER_WHATSAPP_TO=
# Publiczny URL webhooka (np. https://twoja-apka.fly.dev/whatsapp/inbound).
# Gdy ustawiony, kazde przychodzace zadanie Twilio MUSI miec poprawny podpis (X-Twilio-Signature),
# inaczej 403 — chroni publiczny endpoint przed sfalszowanym "TAK" ksiegujacym realny koszt.
WEBHOOK_PUBLIC_URL=

# --- Ksiegowanie (Fakturownia; wymagane gdy INVOICER_SINK=fakturownia) ---
# Pomin/zostaw puste, by ksiegowac do mocka (MockSubiekt) — bez realnych faktur.
INVOICER_SINK=fakturownia
FAKTUROWNIA_API_TOKEN=
FAKTUROWNIA_DOMAIN=

# --- Legal-grounded RAG (pgvector; opcjonalne, ale to flagowa funkcja) ---
# Bez DATABASE_URL store spada do pustego in-memory => faktury zagraniczne lecą sciezka "abstain".
# Gdy DATABASE_URL ustawiony, VOYAGE_API_KEY staje sie wymagany (embeddingi + reranker).
DATABASE_URL=
VOYAGE_API_KEY=

# --- Strojenie (opcjonalne, maja sensowne domyslne) ---
# Czestotliwosc pollingu Gmaila w minutach (domyslnie 5)
INTAKE_INTERVAL_MINUTES=5
# Ile dni wstecz przeszukiwac skrzynke (domyslnie 3) — okno > 1 dzien, by przestoj nie zgubil faktur
GMAIL_LOOKBACK_DAYS=3
# Katalog trwalego stanu (sqlite checkpointer + ledger + token); na Fly to wolumen /data
INVOICER_DATA_DIR=/data

# --- Observability (opcjonalne) ---
LANGSMITH_API_KEY=
SENTRY_DSN=
